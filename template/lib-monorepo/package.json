{
  "name": "@scope/project-monorepo",
  "description": "",
  "license": "MIT",
  "type": "module",
  "private": true,
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "pnpm run -r --stream --filter='./packages/*' dev",
    "build": "pnpm run -r --stream --filter='./packages/*' build",
    "build:tsdown": "tsdown -W",
    "clean:dist": "pnpm run -r --stream clean:dist",
    "clean:nms": "pnpm run -r --stream clean:nm && npx rimraf node_modules",
    "clean:cache": "pnpm store prune",
    "clean:all": "pnpm run -r --stream clean:dist clean:nm && npx rimraf node_modules && pnpm store prune"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^24.13.2",
    "publint": "^0.3.21",
    "typescript": "^6.0.3",
    "tsdown": "^0.22.5"
  },
  "author": {
    "name": "",
    "email": ""
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "monorepo",
    "pnpm"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
